{
	"name": "theatrum-animation",
	"version": "1.0.0",
	"description": "WordPress plugin for adding animations to blocks",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"start": "npm-run-all --parallel watch:main watch:editor",
		"watch:main": "vite build --watch",
		"watch:editor": "vite build --config vite.config.editor.js --watch",
		"build": "vite build && vite build --config vite.config.editor.js",
		"build:watch": "vite build --watch && vite build --config vite.config.editor.js --watch",
		"build:editor": "vite build --config vite.config.editor.js",
		"typecheck": "tsc --noEmit",
		"deploy": "npm run build"
	},
	"devDependencies": {
		"@types/react": "^19.2.17",
		"@types/wordpress__block-editor": "^15.0.6",
		"@vitejs/plugin-react": "^6.0.2",
		"@wordpress/block-editor": "^15.21.0",
		"@wordpress/components": "^35.0.0",
		"@wordpress/compose": "^8.1.0",
		"@wordpress/element": "^8.0.0",
		"@wordpress/hooks": "^4.48.0",
		"@wordpress/i18n": "^6.1.0",
		"npm-run-all": "^4.1.5",
		"sass": "^1.77.0",
		"typescript": "^5.3.0",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"gsap": "^3.15.0"
	}
}
